datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("resident")
  createdAt DateTime @default(now())
}

model Report {
  id        String   @id @default(uuid())
  category  String
  status    String   @default("REPORTED")
  latitude  Float
  longitude Float
  photoUrl  String
  createdBy String
  createdAt DateTime @default(now())
}

model StatusEvent{
  id        String    @id @default(uuid())
  reportId    String
  fromStatus  String?
  toStatus    String
  actorId     String
  evidenceUrl String?
  createdAt   DateTime @default(now())
}



